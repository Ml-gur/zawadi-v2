# Supabase (required for database features)
# Get these from your Supabase project dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# JWT Secret — MUST be set to a cryptographically random string of at least 32 characters before deployment.
# The server will refuse to start if JWT_SECRET is not set or is shorter than 32 characters.
JWT_SECRET=yoursecrethere

# AI Provider Configuration — can also be managed via the admin UI at /admin → AI Configuration
# At least one API key is needed for AI-powered essay generation.
# Without any AI keys, essay generation falls back to template-based content.
# All other site features (scholarships, bot pipeline, etc.) work without AI keys.

# Google Gemini (default)
GOOGLE_API_KEY=your_api_key_here

# OpenAI (alternative)
# OPENAI_API_KEY=sk-...

# DeepSeek (recommended — supports essay generation + document analysis)
# To use DeepSeek, uncomment BOTH lines below:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-...

# Paystack (subscription payments)
VITE_PAYSTACK_PUBLIC_KEY=pk_test_...
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_CALLBACK_URL=https://yourdomain.com

# Pipeline configuration (optional — for scheduled crawling)
CRAWL_DELAY_MS=2000
PIPELINE_SCHEDULE=0 2 * * *
PIPELINE_MIN_SCHOLARSHIPS=200

# Admin credentials — used by scripts/setup-admin.mjs to create/update the admin account
# VITE_ADMIN_EMAIL is exposed to the frontend for login validation only (never the password)
ADMIN_EMAIL=admin@zawadi.com
ADMIN_PASSWORD=change-this-to-a-strong-password
VITE_ADMIN_EMAIL=admin@zawadi.com
